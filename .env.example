# ============================================================================
# MedPrice Tracker — пример переменных окружения
# ============================================================================
# Скопируй этот файл в `.env` и заполни значения:
#   cp .env.example .env
#
# Валидация: src/lib/config/index.ts (zod-схема, fail-fast при ошибке).
# Все переменные без значения (placeholder=...) являются опциональными
# или имеют defaults в zod-схеме — указаны ниже в комментариях.
# ============================================================================

# === Core ===
# Режим приложения. Values: development | production | test. Default: development.
NODE_ENV=development

# Обязательная переменная. Для SQLite — абсолютный или относительный путь к файлу.
DATABASE_URL=file:../db/custom.db

# Порт dev/прод сервера. Default: 3000.
PORT=3000

# === Scope (методология раздел 0.3) ===
# Целевой регион сбора цен. Values: moscow | mo | spb. Default: mo.
TARGET_REGION=mo

# === Logging ===
# Уровень логирования. Values: fatal | error | warn | info | debug | trace. Default: info.
LOG_LEVEL=info

# === Rate limits (politeness, раздел 12) ===
# Минимальная задержка между запросами к одному хосту, мс. Default: 2000.
DEFAULT_RATE_LIMIT_MS=2000

# Максимальное число параллельных запросов к одному хосту. Default: 5.
DEFAULT_CONCURRENCY=5

# Максимальное число ретраев при сетевой ошибке / 5xx. Default: 3.
MAX_RETRIES=3

# === AI Skills quotas (раздел 8) ===
# Суточный лимит VLM (vision-language model) запросов. Default: 100.
VLM_DAILY_QUOTA=100

# Суточный лимит LLM (text) запросов. Default: 1000.
LLM_DAILY_QUOTA=1000

# Суточный лимит Web-Reader запросов. Default: 500.
WEB_READER_DAILY_QUOTA=500

# Суточный лимит Web-Search запросов. Default: 50.
WEB_SEARCH_DAILY_QUOTA=50

# === z-ai SDK ===
# API-ключ z-ai-web-dev-sdk. Опционально (только для VLM/LLM/Web-Reader/Web-Search).
# Получить: https://z.ai/api
ZAI_API_KEY=

# === API protection ===
# Опционально в development. Обязательно в production для POST /api/* и /api/download/*.
# Передавай как header: X-API-Key: <значение> или Authorization: Bearer <значение>.
ADMIN_API_KEY=

# === Storage ===
# Путь к raw-lake (HTML/JSON-снапшоты для аудита). Default: ./data/raw-lake.
RAW_LAKE_PATH=./data/raw-lake

# Путь к скриншотам (T8 VLM fallback). Default: ./data/screenshots.
SCREENSHOTS_PATH=./data/screenshots

# === Proxy (для Helix-Москва и других сайтов с ip_default, раздел 14.7) ===
# Опционально. URL прокси: http://proxy.host:port или socks5://...
PROXY_URL=
# Опционально. Логин/пароль для аутентификации на прокси.
PROXY_USER=
PROXY_PASS=

# === Telegram alerts (раздел 17.6) ===
# Опционально. Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=
# Опционально. ID чата или канала для уведомлений (например, -1001234567890).
TELEGRAM_CHAT_ID=
